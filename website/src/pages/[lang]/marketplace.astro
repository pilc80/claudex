---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getMarketplaceStrings, SUPPORTED_LOCALES } from '../../lib/i18n/marketplace';
import registry from '../../../../sets.json';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = getMarketplaceStrings(lang!);
const sets = registry.sets;

function extractGitHubRepo(homepage: string): string | null {
  const match = homepage.match(/github\.com\/([^/]+\/[^/]+)/);
  return match ? match[1] : null;
}
---

<StarlightPage frontmatter={{ title: t.pageTitle, description: t.pageDescription, tableOfContents: false, template: 'splash', pagefind: false, prev: false, next: false }}>
  <div class="marketplace-full">
    <p class="marketplace-intro">
      {t.intro}
    </p>

    <div class="sets-grid">
      {sets.map((set) => {
        const repo = extractGitHubRepo(set.homepage);
        return (
          <div class="set-card">
            <div class="set-header">
              <h3 class="set-name">
                <a href={set.homepage} target="_blank" rel="noopener">{set.name}</a>
              </h3>
              <span class="set-version">v{set.version}</span>
              {repo && (
                <span class="set-stars" data-repo={repo} title="GitHub Stars">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
                  <span class="star-count">...</span>
                </span>
              )}
            </div>
            <p class="set-description">{set.description}</p>
            <div class="set-meta">
              <span class="set-author">{t.byAuthor(set.author)}</span>
            </div>
            <div class="set-components">
              {set.components.claude_md && <span class="badge">CLAUDE.md</span>}
              {set.components.rules > 0 && <span class="badge">{t.rules(set.components.rules)}</span>}
              {set.components.skills > 0 && <span class="badge">{t.skills(set.components.skills)}</span>}
              {set.components.mcp_servers > 0 && <span class="badge">{set.components.mcp_servers} MCP</span>}
            </div>
            {set.tags && set.tags.length > 0 && (
              <div class="set-tags">
                {set.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
            <div class="install-section">
              <div class="install-group">
                <span class="install-label">{t.installGlobal}</span>
                <div class="install-row">
                  <code class="install-cmd">claudex-config sets add --global {set.source}</code>
                  <button class="copy-btn" data-cmd={`claudex-config sets add --global ${set.source}`} title={t.copyTooltip}>
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"/></svg>
                  </button>
                </div>
              </div>
              <div class="install-group">
                <span class="install-label">{t.installProject}</span>
                <div class="install-row">
                  <code class="install-cmd">claudex-config sets add {set.source}</code>
                  <button class="copy-btn" data-cmd={`claudex-config sets add ${set.source}`} title={t.copyTooltip}>
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <div class="contribute-section">
      <h2>{t.submitTitle}</h2>
      <p set:html={t.submitDescription} />
    </div>
  </div>
</StarlightPage>

<style>
  /* Full-width override: use [data-has-hero] which is set by splash template regardless of language */
  :global([data-has-hero] .main-frame) {
    max-width: 100%;
  }
  :global([data-has-hero] .content-panel) {
    max-width: 100%;
  }
  :global([data-has-hero] main) {
    max-width: 100%;
  }

  .marketplace-full {
    width: 100%;
    max-width: 100%;
    padding: 0 1rem;
  }

  .marketplace-intro {
    color: var(--sl-color-gray-2);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .sets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 40rem) {
    .sets-grid {
      grid-template-columns: 1fr;
    }
  }

  .set-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1.25rem;
    background: var(--sl-color-bg-nav);
    transition: border-color 0.2s;
  }

  .set-card:hover {
    border-color: var(--sl-color-accent);
  }

  .set-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .set-name {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
  }

  .set-name a {
    color: var(--sl-color-white);
    text-decoration: none;
  }

  .set-name a:hover {
    color: var(--sl-color-accent);
  }

  .set-version {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    font-family: var(--sl-font-mono);
  }

  .set-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    margin-left: auto;
  }

  .set-stars svg {
    color: #eab308;
  }

  .star-count {
    font-family: var(--sl-font-mono);
  }

  .set-description {
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
    margin: 0.25rem 0 0.5rem;
    line-height: 1.5;
  }

  .set-meta {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.5rem;
  }

  .set-components {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
  }

  .badge {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    font-weight: 500;
  }

  .set-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .tag {
    font-size: 0.65rem;
    padding: 0.05rem 0.35rem;
    border-radius: 0.2rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
  }

  .install-section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--sl-color-gray-6);
  }

  .install-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .install-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
  }

  .install-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .install-cmd {
    flex: 1;
    font-size: 0.75rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.375rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font-mono);
    overflow-x: auto;
    white-space: nowrap;
  }

  .copy-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition: all 0.15s;
  }

  .copy-btn:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .copy-btn.copied {
    border-color: #22c55e;
    color: #22c55e;
  }

  .contribute-section {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1px dashed var(--sl-color-gray-5);
    border-radius: 0.75rem;
    text-align: center;
  }

  .contribute-section h2 {
    margin-top: 0;
    font-size: 1.1rem;
  }

  .contribute-section :global(p) {
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  .contribute-section :global(code) {
    font-size: 0.8rem;
    padding: 0.1rem 0.3rem;
    border-radius: 0.2rem;
    background: var(--sl-color-gray-6);
  }

  .contribute-section :global(a) {
    color: var(--sl-color-accent);
    text-decoration: none;
  }

  .contribute-section :global(a:hover) {
    text-decoration: underline;
  }
</style>

<script>
  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const cmd = btn.getAttribute('data-cmd');
      if (!cmd) return;
      try {
        await navigator.clipboard.writeText(cmd);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      } catch {
        const code = btn.previousElementSibling;
        if (code) {
          const range = document.createRange();
          range.selectNodeContents(code);
          const sel = window.getSelection();
          if (sel) {
            sel.removeAllRanges();
            sel.addRange(range);
          }
        }
      }
    });
  });

  // Fetch GitHub stars
  document.querySelectorAll('.set-stars[data-repo]').forEach(async (el) => {
    const repo = el.getAttribute('data-repo');
    if (!repo) return;
    try {
      const resp = await fetch(`https://api.github.com/repos/${repo}`);
      if (resp.ok) {
        const data = await resp.json();
        const count = data.stargazers_count;
        const display = count >= 1000 ? `${(count / 1000).toFixed(1)}k` : String(count);
        const span = el.querySelector('.star-count');
        if (span) span.textContent = display;
      }
    } catch {
      // silently fail
    }
  });
</script>
